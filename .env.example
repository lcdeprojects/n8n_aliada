# ==============================================================================
# Configurações do Django
# ==============================================================================
SECRET_KEY=sua-django-secret-key-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ==============================================================================
# Conexão com o Banco de Dados (Supabase PostgreSQL)
# ==============================================================================
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=sua-senha-do-banco-supabase-aqui
DB_HOST=seu-host-do-supabase.supabase.co
DB_PORT=5432

# ==============================================================================
# Configurações da Evolution API (WhatsApp)
# ==============================================================================
EVOLUTION_API_URL=https://sua-api-evolution.hostinger.com
EVOLUTION_API_API_KEY=sua-api-key-global-da-evolution-aqui
EVOLUTION_API_INSTANCE_NAME=nome-da-sua-instancia-aqui

# ==============================================================================
# Inteligência Artificial (OpenAI / Outros)
# ==============================================================================
OPENAI_API_KEY=sua-api-key-da-openai-aqui
AI_MODEL=gpt-4o-mini
